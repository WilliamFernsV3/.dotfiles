{
  "github.copilot.enable": {
    "markdown": true
  },
  "debug.console.fontFamily": "",
  "terminal.integrated.fontFamily": "MesloLGS Nerd Font Mono",
  "editor.minimap.enabled": false,
  "editor.lineNumbers": "relative",
  "python.languageServer": "Pylance",
  "[python]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.codeActionsOnSave": {
      "source.fixAll": "explicit",
      "source.organizeImports": "explicit"
    }
  },
  "editor.codeActionsOnSave": {
    "source.organizeImports": "always",
    "source.removeUnusedImports": "always"
  },
  "python.analysis.autoImportCompletions": true,
  "python.analysis.completeFunctionParens": true,
  "python.analysis.inlayHints.functionReturnTypes": true,
  "python.analysis.inlayHints.pytestParameters": true,
  "python.analysis.inlayHints.variableTypes": true,
  "python.analysis.typeCheckingMode": "standard",
  "python.analysis.autoFormatStrings": true,
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "editor.formatOnSave": true,
  "macros": {
    "resizeSidebarDecrease": ["workbench.action.increaseViewSize"],
    "resizeSidebarIncrease": ["workbench.action.decreaseViewSize"]
  },
  "search.useIgnoreFiles": false,
  "search.exclude": {
    "**/node_modules": true,
    "**/bower_components": true,
    "**/*.code-search": true,
    "**/.venv": true,
    "**/.mypy_cache": true,
    "**/__pycache__": true,
    "**/.next": true
  },
  "nix.enableLanguageServer": true,
  "nix.serverSettings": {
    "nixd": {
      "formatting": {
        "command": ["nixpkgs-fmt"]
      },
      "options": {
        // By default, this entriy will be read from `import <nixpkgs> { }`.
        // You can write arbitary Nix expressions here, to produce valid "options" declaration result.
        // Tip: for flake-based configuration, utilize `builtins.getFlake`
        //   "nixos": {
        //     "expr": "(builtins.getFlake \"/absolute/path/to/flake\").nixosConfigurations.<name>.options"
        //   },
        //   "home-manager": {
        //     "expr": "(builtins.getFlake \"/absolute/path/to/flake\").homeConfigurations.<name>.options"
        //   },
        //   // Tip: use ${workspaceFolder} variable to define path
        //   "nix-darwin": {
        //     "expr": "(builtins.getFlake \"${workspaceFolder}/path/to/flake\").darwinConfigurations.<name>.options"
        //   }
        // }
      }
    }
  },
  "workbench.colorTheme": "Catppuccin Mocha",
  "workbench.iconTheme": "vscode-icons",
  "nix.serverPath": "/nix/var/nix/profiles/default/bin/nix",
  "task.allowAutomaticTasks": "on",
  "diffEditor.maxComputationTime": 0,
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "editor.largeFileOptimizations": false,
  "diffEditor.renderSideBySide": false,
  "notebook.formatOnSave.enabled": true,
  "notebook.codeActionsOnSave": {
    "notebook.source.fixAll": "explicit",
    "notebook.source.organizeImports": "explicit"
  },
  "ruff.configurationPreference": "filesystemFirst",
  "ruff.nativeServer": "on"
}
